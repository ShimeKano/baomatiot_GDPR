# Server
PORT=4280
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h
DEFAULT_ADMIN_EMAIL=22004249@st.vlute.edu.vn
DATA_FILE=./data/store.json
TZ=Asia/Ho_Chi_Minh
DAILY_EMAIL_HOUR=7
DAILY_EMAIL_MINUTE=0

# MQTT ingestion (public broker — no credentials required for test.mosquitto.org)
MQTT_BROKER_URL=mqtt://test.mosquitto.org
MQTT_TELEMETRY_TOPIC=iot/gdpr/telemetry
MQTT_TOPIC=
MQTT_USERNAME=
MQTT_PASSWORD=

# SMTP for daily summaries
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password
SMTP_FROM=no-reply@example.com
